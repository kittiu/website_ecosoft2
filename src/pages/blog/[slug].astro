---
import { getCollection } from 'astro:content';
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatDate } from '../../utils/formatDate';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={`${post.data.title} | Ecosoft Blog`} description={post.data.description}>
  <article class="post-wrap">
    <div class="container">
      <a href="/blog" class="back-link">← Back to Blog</a>

      <header class="post-header">
        <div class="post-meta">
          <span class="blog-category">{post.data.category}</span>
          <span class="post-date">{formatDate(post.data.date)}</span>
          <span class="post-author">By {post.data.author}</span>
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
        {post.data.tags && (
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <span class="post-tag">#{tag}</span>
            ))}
          </div>
        )}
      </header>

      {post.data.image && (
        <div class="post-cover">
          <img src={post.data.image} alt={post.data.title} class="post-cover-img" />
        </div>
      )}

      <div class="post-body">
        <Content />
      </div>

      <div class="post-cta">
        <p class="post-cta-eyebrow">Ready to take the next step?</p>
        <h2 class="post-cta-heading">Let's Talk About Your ERP Project</h2>
        <p class="post-cta-body">
          Ecosoft has helped 40+ Thai organisations implement Odoo and ERPNext — from
          manufacturing and logistics to government agencies and space technology.
          Get a free, no-obligation consultation with our team.
        </p>
        <div class="post-cta-actions">
          <a href="/#contact" class="btn btn-primary">Request a Free Consultation</a>
          <a href="/about" class="btn btn-outline">Learn about Ecosoft</a>
        </div>
      </div>

      <footer class="post-footer">
        <a href="/blog" class="btn btn-outline">← Back to Blog</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .post-wrap {
    padding-block: 3rem 4rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: #1d4ed8;
    margin-bottom: 2rem;
    text-decoration: none;
  }

  .back-link:hover {
    color: #f97316;
  }

  .post-header {
    max-width: 44rem;
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border-blue);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.82rem;
  }

  .blog-category {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #f97316;
  }

  .post-date,
  .post-author {
    color: var(--text-faint);
  }

  .post-title {
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
    color: var(--text);
    line-height: 1.15;
  }

  .post-description {
    margin: 0 0 1rem;
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .post-tag {
    font-size: 0.72rem;
    color: #1d4ed8;
    background: var(--bg-card-blue);
    border: 1px solid var(--border-blue);
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
  }

  .post-body {
    max-width: 44rem;
    font-size: 0.97rem;
    line-height: 1.8;
    color: var(--text);
  }

  .post-body :global(h2) {
    font-size: 1.35rem;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 2rem 0 0.6rem;
  }

  .post-body :global(h3) {
    font-size: 1.1rem;
    color: var(--text);
    margin: 1.5rem 0 0.4rem;
  }

  .post-body :global(p) {
    margin: 0 0 1rem;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.4rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.3rem;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid #f97316;
    margin: 1.5rem 0;
    padding: 0.75rem 1.2rem;
    background: var(--bg-card-blue);
    border-radius: 0 0.5rem 0.5rem 0;
    font-style: italic;
    color: var(--text-subtle);
  }

  .post-body :global(blockquote p) {
    margin: 0 0 0.3rem;
  }

  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.2rem 0;
    font-size: 0.9rem;
  }

  .post-body :global(th) {
    background: var(--bg-card-blue);
    padding: 0.5rem 0.8rem;
    text-align: left;
    font-weight: 600;
    border: 1px solid var(--border-blue);
    color: var(--text);
  }

  .post-body :global(td) {
    padding: 0.5rem 0.8rem;
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .post-body :global(strong) {
    color: var(--text);
  }

  .post-body :global(code) {
    background: var(--bg-card-blue);
    padding: 0.15rem 0.4rem;
    border-radius: 0.3rem;
    font-size: 0.88em;
  }

  .post-cover {
    max-width: 44rem;
    margin-bottom: 2rem;
    border-radius: 0.9rem;
    overflow: hidden;
    border: 1px solid var(--border-blue);
  }

  .post-cover-img {
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    display: block;
  }

  .post-cta {
    max-width: 44rem;
    margin-top: 3rem;
    padding: 2rem 2.2rem;
    border-radius: 1.2rem;
    background: radial-gradient(circle at top left, #2563eb 0, #bfdbfe 60%);
    color: #0f172a;
  }

  .post-cta-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #1d4ed8;
    margin: 0 0 0.5rem;
  }

  .post-cta-heading {
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    color: #0f172a;
  }

  .post-cta-body {
    font-size: 0.9rem;
    line-height: 1.65;
    color: #1e3a5f;
    margin: 0 0 1.25rem;
    max-width: 38rem;
  }

  .post-cta-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .post-footer {
    max-width: 44rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
</style>
