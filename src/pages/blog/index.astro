---
import { getCollection } from 'astro:content';
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatDate } from '../../utils/formatDate';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Blog | Ecosoft — ERP Insights & Case Studies"
  description="ERP insights, case studies, and open source know-how from the Ecosoft team. Real stories from real implementations across Thailand."
>
  <section class="blog-hero">
    <div class="container">
      <p class="eyebrow">Ecosoft Blog</p>
      <h1>ERP Insights, Case Studies &amp; Open Source Expertise</h1>
      <p class="blog-hero-lead">
        Practical guidance from over a decade of ERP implementations across Thailand —
        from manufacturing and logistics to government and space technology.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length === 0 && (
        <div class="blog-empty">
          <p class="blog-empty-title">No articles published yet.</p>
          <p class="blog-empty-sub">We'll be sharing ERP insights, case studies, and open source guides soon. <a href="/#contact">Get in touch</a> if you have a question in the meantime.</p>
        </div>
      )}
      <div class="blog-list">
        {posts.map((post) => (
          <article class="blog-card">
            {post.data.image && (
              <a href={`/blog/${post.slug}`} class="blog-card-img-wrap">
                <img src={post.data.image} alt={post.data.title} class="blog-card-img" />
              </a>
            )}
            <div class="blog-card-body">
              <div class="blog-card-meta">
                <span class="blog-category">{post.data.category}</span>
                <span class="blog-date">{formatDate(post.data.date)}</span>
              </div>
              <h2 class="blog-card-title">
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h2>
              <p class="blog-card-desc">{post.data.description}</p>
              <div class="blog-card-footer">
                <span class="blog-author">By {post.data.author}</span>
                <a href={`/blog/${post.slug}`} class="blog-read-more">Read more →</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    padding-block: 3.5rem 3rem;
    background:
      radial-gradient(circle at top left, var(--border-blue) 0, transparent 60%),
      linear-gradient(to bottom, var(--bg) 0%, var(--bg-card-blue) 40%, var(--bg) 70%);
  }

  .blog-hero h1 {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
    color: var(--text);
  }

  .blog-hero-lead {
    margin: 0;
    color: var(--text-muted);
    max-width: 36rem;
    font-size: 1rem;
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 52rem;
  }

  .blog-card {
    display: grid;
    grid-template-columns: 220px 1fr;
    border-radius: 1.1rem;
    border: 1px solid var(--border-blue);
    background: var(--bg-card);
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.07);
    overflow: hidden;
    transition: box-shadow 150ms ease-out;
  }

  .blog-card:hover {
    box-shadow: 0 12px 32px rgba(59, 130, 246, 0.15);
  }

  .blog-card-img-wrap {
    display: block;
    overflow: hidden;
  }

  .blog-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 200ms ease-out;
    will-change: transform;
  }

  .blog-card:hover .blog-card-img {
    transform: scale(1.04);
  }

  .blog-card-body {
    padding: 1.4rem 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .blog-category {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #f97316;
  }

  .blog-date {
    font-size: 0.78rem;
    color: var(--text-faint);
  }

  .blog-card-title {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.3;
  }

  .blog-card-title a {
    color: inherit;
    text-decoration: none;
  }

  .blog-card-title a:hover {
    color: #1d4ed8;
  }

  .blog-card-desc {
    margin: 0 0 1rem;
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
    flex: 1;
  }

  .blog-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.82rem;
  }

  .blog-author {
    color: var(--text-subtle);
  }

  .blog-read-more {
    color: #1d4ed8;
    font-weight: 600;
    text-decoration: none;
  }

  .blog-read-more:hover {
    color: #f97316;
  }

  @media (max-width: 600px) {
    .blog-card {
      grid-template-columns: 1fr;
    }

    .blog-card-img-wrap {
      height: 180px;
    }
  }

  .blog-empty {
    padding: 3rem 0;
    max-width: 40rem;
  }

  .blog-empty-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.5rem;
  }

  .blog-empty-sub {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin: 0;
  }

  .blog-empty-sub a {
    color: #1d4ed8;
    font-weight: 600;
  }

  @media (max-width: 360px) {
    .blog-card-body {
      padding: 1rem;
    }

    .blog-card-title {
      font-size: 1rem;
    }
  }
</style>
