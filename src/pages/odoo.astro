---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="Odoo ERP | Ecosoft — Open Source ERP Solutions"
  description="Odoo ERP: modular, fully integrated, and open-source. Trusted by 12M+ businesses worldwide. Consulting, implementation, and support by Ecosoft in Thailand."
>
  <!-- HERO -->
  <section class="odoo-hero">
    <div class="container odoo-hero-inner">
      <div class="odoo-hero-copy">
        <p class="eyebrow">Modular · Fully Integrated · Open-source</p>
        <h1>Odoo ERP: Modular, Integrated,<br />Built for Growth.</h1>
        <p class="odoo-hero-lead">
          One platform for every business function — accounting, CRM, inventory,
          manufacturing, HR, and e-commerce. Odoo is trusted by 12M+ organisations
          worldwide. Ecosoft clients in Thailand save 60–80% versus SAP licensing costs.
        </p>
        <div class="odoo-hero-actions">
          <a href="/#contact" class="btn btn-primary">Request a Free Consultation</a>
          <a href="#modules" class="btn btn-outline">Explore modules</a>
        </div>
      </div>
      <div class="product-hero-panel">
        <div class="product-hero-logo">
          <img src="/images/odoo-logo.png" alt="Odoo" />
        </div>
        <div class="product-hero-stats">
          <div class="product-stat">
            <p class="product-stat-number">12M+</p>
            <p class="product-stat-label">Users worldwide</p>
          </div>
          <div class="product-stat">
            <p class="product-stat-number">40K+</p>
            <p class="product-stat-label">Add-on apps</p>
          </div>
          <div class="product-stat">
            <p class="product-stat-number">฿0</p>
            <p class="product-stat-label">License fees (Community)</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUE PROPOSITION -->
  <section class="section section-alt">
    <div class="container odoo-value-inner">
      <header class="section-header">
        <p class="eyebrow">Why Odoo</p>
        <h2>A Complete Business Platform, Not Just an ERP</h2>
      </header>
      <p class="odoo-value-body">
        One system for sales, accounting, HR, inventory, manufacturing, and e-commerce.
        Every team sees the same real-time data — no manual exports, no spreadsheet
        reconciliation, no version conflicts. Just one source of truth across the organisation.
      </p>
      <p class="odoo-value-body">
        Odoo comes in two editions. Community Edition is 100% free and open source — ideal
        for organisations that want full control. Enterprise Edition adds advanced modules,
        official Odoo support, and cloud hosting. Both adapt to your processes through
        40,000+ apps and an open API. Don't compromise your workflows to fit your ERP.
      </p>
      <div class="odoo-value-highlights">
        <div class="odoo-value-highlight">
          <strong>Community Edition</strong>
          <span>Core ERP modules with zero license fees, self-hosted and fully open source</span>
        </div>
        <div class="odoo-value-highlight">
          <strong>Enterprise Edition</strong>
          <span>Advanced modules, official Odoo support, mobile apps, and cloud hosting</span>
        </div>
      </div>
    </div>
  </section>

  <!-- EDITIONS COMPARISON -->
  <section class="section">
    <div class="container">
      <header class="section-header">
        <p class="eyebrow">Editions</p>
        <h2>Community vs Enterprise: Choose the Right Edition for Your Organisation</h2>
      </header>
      <div class="odoo-editions-grid">
        <div class="info-card odoo-edition-card">
          <h3>Community Edition</h3>
          <p class="odoo-edition-tag">Free &amp; Open Source</p>
          <ul class="odoo-edition-list">
            <li>Core ERP modules included</li>
            <li>Self-hosted flexibility</li>
            <li>Strong community support</li>
            <li>40,000+ add-on apps</li>
            <li>No license fees ever</li>
          </ul>
        </div>
        <div class="info-card odoo-edition-card odoo-edition-featured">
          <h3>Enterprise Edition</h3>
          <p class="odoo-edition-tag">Full-Featured</p>
          <ul class="odoo-edition-list">
            <li>All Community features</li>
            <li>Advanced modules (Studio, Sign, IoT…)</li>
            <li>Odoo cloud hosting option</li>
            <li>Official Odoo support</li>
            <li>Mobile apps included</li>
            <li>Upgrade assistance</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- MODULES -->
  <section id="modules" class="section section-alt">
    <div class="container">
      <header class="section-header">
        <p class="eyebrow">Modules</p>
        <h2>Modules Powering Every Part of Your Business</h2>
        <p>
          Odoo ERP brings every business function under one roof with seamless integration and a
          beautiful, user-friendly interface.
        </p>
      </header>
      <div class="cards-grid odoo-modules-grid">
        {[
          {
            icon: "📒",
            name: "Finance & Accounting",
            desc: "Everything from invoices and expenses to multi-company consolidation, handled in one seamlessly integrated suite.",
          },
          {
            icon: "💼",
            name: "Sales & Customer Management",
            desc: "Close deals faster with CRM, sales automation, subscriptions, and real-time POS — all under one tab.",
          },
          {
            icon: "📦",
            name: "Inventory & Procurement",
            desc: "Stay in control with smart stock movements, automated purchasing, and streamlined warehouse management.",
          },
          {
            icon: "🏭",
            name: "Manufacturing & Operations",
            desc: "End-to-end manufacturing, quality, maintenance, and product lifecycle tools for total shop floor control.",
          },
          {
            icon: "📋",
            name: "Projects & Time Tracking",
            desc: "Plan, assign, and monitor projects, timesheets, and appointments with ease and clarity.",
          },
          {
            icon: "🛍️",
            name: "Website & E-Commerce",
            desc: "Build stunning websites, sell online, manage field service, and digitize signatures all in one place.",
          },
          {
            icon: "📣",
            name: "Marketing & Engagement",
            desc: "Automate campaigns, manage events, and drive engagement with fully integrated marketing tools.",
          },
          {
            icon: "👥",
            name: "HR & Employee Experience",
            desc: "Hire, manage, appraise, and retain top talent with a complete HR toolkit.",
          },
          {
            icon: "🎓",
            name: "Learning & Customization",
            desc: "Empower teams with eLearning and customize anything with no code using Odoo Studio.",
          },
          {
            icon: "🔗",
            name: "Smart Integrations & Approvals",
            desc: "Connect devices, streamline approvals, manage docs, and go paperless with powerful system-level features.",
          },
        ].map((m) => (
          <div class="info-card">
            <span class="odoo-module-icon">{m.icon}</span>
            <h3>{m.name}</h3>
            <p>{m.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFFERENTIATORS -->
  <section class="section">
    <div class="container">
      <header class="section-header">
        <p class="eyebrow">Differentiators</p>
        <h2>What Sets Odoo Apart from Traditional ERP</h2>
        <p>
          Not all ERP platforms are built equal. Odoo's open-source foundation, modular architecture,
          and global community deliver capabilities that proprietary systems simply cannot match.
        </p>
      </header>
      <div class="cards-grid odoo-diff-grid">
        {[
          {
            icon: "🔓",
            title: "No Vendor Lock-In",
            desc: "Total freedom to host, modify, and scale on your terms.",
          },
          {
            icon: "🌍",
            title: "Globally Trusted",
            desc: "Proven ERP platform with over 12 million users worldwide.",
          },
          {
            icon: "⚡",
            title: "All-in-One Functionality",
            desc: "Everything from sales to support in one integrated system.",
          },
          {
            icon: "🧩",
            title: "40,000+ Add-On Apps",
            desc: "Extend capabilities with ready-to-use apps from the Odoo App Store.",
          },
          {
            icon: "🤝",
            title: "Vibrant Global Community",
            desc: "Thousands of developers and users improving Odoo every day.",
          },
        ].map((d) => (
          <div class="info-card odoo-diff-card">
            <span class="odoo-diff-icon">{d.icon}</span>
            <h3>{d.title}</h3>
            <p>{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INTEGRATIONS -->
  <section class="section section-alt">
    <div class="container odoo-integrations">
      <header class="section-header">
        <p class="eyebrow">Integrations</p>
        <h2>Connect Anything. Sync Everything.</h2>
        <p>
          From e-commerce platforms to payment gateways, Odoo integrates effortlessly with 130+
          tools — so your entire tech stack works in perfect harmony.
        </p>
      </header>
      <div class="odoo-integration-image">
        <img
          src="/images/erpnext_integrations.webp"
          alt="Odoo integrations including PayPal, Stripe, Shopify, Google, AWS, Slack and more"
        />
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="section">
    <div class="container">
      <header class="section-header">
        <p class="eyebrow">Pricing</p>
        <h2>Odoo Implementation Packages</h2>
        <p>
          Odoo Community Edition carries zero license fees. Enterprise Edition includes
          official Odoo support and advanced modules — an additional per-user Odoo license applies.
          All packages below cover Ecosoft consulting and implementation services.
        </p>
      </header>

      <div class="pricing-tabs">
        <button class="pricing-tab pricing-tab--active" data-tab="odoo-standard">Standard</button>
        <button class="pricing-tab" data-tab="odoo-enterprise">Enterprise</button>
      </div>

      <div class="pricing-panel" data-panel="odoo-standard">
        <div class="pricing-grid">
          <div class="pricing-card">
            <div class="pricing-card-header">
              <h3 class="pricing-plan">HRMS / Payroll Only</h3>
              <div class="pricing-price">
                <span class="pricing-amount">฿250,000</span>
              </div>
              <p class="pricing-scope">Odoo HR</p>
            </div>
            <ul class="pricing-features">
              <li>30 consulting hours</li>
              <li>30-day project validity</li>
              <li>HR &amp; Payroll modules</li>
              <li>Thai payroll compliance</li>
            </ul>
            <a href="/#contact" class="btn btn-outline pricing-cta">Get started</a>
          </div>

          <div class="pricing-card">
            <div class="pricing-card-header">
              <h3 class="pricing-plan">Core Odoo</h3>
              <div class="pricing-price">
                <span class="pricing-amount">฿300,000</span>
              </div>
              <p class="pricing-scope">Accounting · Selling · Buying · Inventory</p>
            </div>
            <ul class="pricing-features">
              <li>40 consulting hours</li>
              <li>30-day project validity</li>
              <li>Thai accounting &amp; tax compliance</li>
              <li>Full source code delivery</li>
            </ul>
            <a href="/#contact" class="btn btn-outline pricing-cta">Get started</a>
          </div>

          <div class="pricing-card pricing-card--featured">
            <div class="pricing-badge">Most Popular</div>
            <div class="pricing-card-header">
              <h3 class="pricing-plan">Core + Manufacturing</h3>
              <div class="pricing-price">
                <span class="pricing-amount">฿500,000</span>
              </div>
              <p class="pricing-scope">Above + Manufacturing</p>
            </div>
            <ul class="pricing-features">
              <li>70 consulting hours</li>
              <li>60-day project validity</li>
              <li>Full core ERP scope</li>
              <li>Production &amp; BOM management</li>
              <li>Thai accounting &amp; tax compliance</li>
              <li>Full source code delivery</li>
            </ul>
            <a href="/#contact" class="btn btn-primary pricing-cta">Get started</a>
          </div>

          <div class="pricing-card">
            <div class="pricing-card-header">
              <h3 class="pricing-plan">Core + Manufacturing + HRMS</h3>
              <div class="pricing-price">
                <span class="pricing-amount">฿750,000</span>
              </div>
              <p class="pricing-scope">Above + Odoo HR</p>
            </div>
            <ul class="pricing-features">
              <li>100 consulting hours</li>
              <li>90-day project validity</li>
              <li>Full core + manufacturing scope</li>
              <li>HR &amp; Payroll modules</li>
              <li>Thai payroll compliance</li>
              <li>Full source code delivery</li>
            </ul>
            <a href="/#contact" class="btn btn-outline pricing-cta">Get started</a>
          </div>
        </div>
        <p class="pricing-enterprise-note">Community Edition: no Odoo license fee. Includes full source code delivery and Thai compliance modules.</p>
      </div>

      <div class="pricing-panel pricing-panel--hidden" data-panel="odoo-enterprise">
        <div class="pricing-grid pricing-grid--centered">
          <div class="pricing-card pricing-card--featured">
            <div class="pricing-card-header">
              <h3 class="pricing-plan">Enterprise</h3>
              <div class="pricing-price">
                <span class="pricing-amount">฿1,500,000+</span>
              </div>
              <p class="pricing-scope">Complex Org · Odoo Enterprise License · Accounting Advisory</p>
            </div>
            <ul class="pricing-features">
              <li>Unlimited consulting hours</li>
              <li>90–270 day project validity</li>
              <li>Odoo Enterprise license included</li>
              <li>Advanced modules (Studio, Sign, IoT…)</li>
              <li>Official Odoo cloud hosting option</li>
              <li>Dedicated accounting advisory</li>
              <li>Full source code delivery</li>
            </ul>
            <a href="/#contact" class="btn btn-primary pricing-cta">Talk to us</a>
          </div>
        </div>
        <p class="pricing-enterprise-note">Pricing ranges from ฿1,500,000 to ฿3,000,000+ depending on scope and user count. Contact us for a tailored quote.</p>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section section-accent odoo-cta">
    <div class="container">
      <h2>Ready to See Odoo in Action?</h2>
      <p>
        Zero license fees (Community) or full enterprise features with official Odoo support.
        Either way, Ecosoft handles implementation, Thai compliance, training, and long-term
        support — so your team is productive from day one.
      </p>
      <a href="/#contact" class="btn btn-primary">Request a Free Consultation</a>
    </div>
  </section>
</BaseLayout>

<script>
  (function () {
    const tabs = document.querySelectorAll('.pricing-tab');
    const panels = document.querySelectorAll('.pricing-panel');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('pricing-tab--active'));
        panels.forEach(p => p.classList.add('pricing-panel--hidden'));
        tab.classList.add('pricing-tab--active');
        document.querySelector(`[data-panel="${(tab as HTMLElement).dataset.tab}"]`)
          ?.classList.remove('pricing-panel--hidden');
      });
    });
  })();
</script>

<style>
  /* Hero — override global grid so panel gets equal column */
  .odoo-hero-inner {
    grid-template-columns: 1fr 1fr;
  }

  .product-hero-panel {
    background: linear-gradient(145deg, var(--bg-card), var(--bg-card-blue));
    border: 1px solid var(--border-blue);
    border-radius: 1.2rem;
    padding: 1.75rem;
    box-shadow: 0 10px 32px rgba(59, 130, 246, 0.12);
  }

  .product-hero-panel .product-hero-logo {
    justify-content: flex-start;
    margin-bottom: 1.5rem;
  }

  .product-hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-blue);
  }

  .product-stat-number {
    margin: 0 0 0.15rem;
    font-size: 1.4rem;
    font-weight: 800;
    color: #f97316;
    line-height: 1;
  }

  .product-stat-label {
    margin: 0;
    font-size: 0.7rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  /* Hero */
  .odoo-hero {
    padding-block: 5rem;
    background: linear-gradient(
      135deg,
      #f9f5f8 0%,
      #ead8e6 25%,
      #d9bdd3 50%,
      #ead8e6 75%,
      #f9f5f8 100%
    );
  }

  html[data-theme="dark"] .odoo-hero {
    background: linear-gradient(
      135deg,
      #1a0e17 0%,
      #3b1f34 25%,
      #4d2945 50%,
      #3b1f34 75%,
      #1a0e17 100%
    );
  }

  .odoo-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.04em;
    margin: 0.5rem 0 1rem;
    color: var(--text);
  }

  .odoo-hero-lead {
    max-width: 42rem;
    font-size: 1.05rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .odoo-hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Value proposition */
  .odoo-value-body {
    max-width: 52rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .odoo-value-highlights {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
    max-width: 52rem;
  }

  .odoo-value-highlight {
    padding: 1.2rem 1.4rem;
    background: var(--bg-card);
    border: 1px solid var(--border-blue);
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .odoo-value-highlight strong {
    font-size: 0.9rem;
    color: #2563eb;
  }

  .odoo-value-highlight span {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Editions */
  .odoo-editions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 52rem;
    margin: 0 auto;
  }

  .odoo-edition-card h3 {
    margin: 0 0 0.3rem;
  }

  .odoo-edition-tag {
    font-size: 0.78rem;
    font-weight: 600;
    color: #2563eb;
    margin: 0 0 1rem;
  }

  .odoo-edition-featured {
    border-color: #2563eb;
    box-shadow: 0 10px 32px rgba(37, 99, 235, 0.22);
  }

  .odoo-edition-list {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.9rem;
    color: var(--text-muted);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .odoo-edition-list li::before {
    content: "✓ ";
    color: #16a34a;
    font-weight: 700;
  }

  /* Modules */
  .odoo-modules-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .odoo-module-icon {
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--bg-card-blue);
    border: 1px solid var(--border-blue);
    border-radius: 10px;
    margin-bottom: 0.75rem;
    flex-shrink: 0;
  }

  /* Differentiators */
  .odoo-diff-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .odoo-diff-icon {
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--bg-card-blue);
    border: 1px solid var(--border-blue);
    border-radius: 10px;
    margin-bottom: 0.75rem;
    flex-shrink: 0;
  }

  /* Integrations */
  .odoo-integration-image {
    margin-top: 2rem;
    padding: 2rem;
    border-radius: 1.2rem;
    border: 1px solid var(--border-blue);
    background: var(--bg-card);
  }

  .odoo-integration-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  html[data-theme="dark"] .odoo-integration-image img {
    filter: brightness(0.85) contrast(1.1);
  }

  /* CTA */
  .odoo-cta {
    text-align: center;
  }

  .odoo-cta h2 {
    font-size: 1.9rem;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .odoo-cta p {
    max-width: 38rem;
    margin: 0 auto 2rem;
    font-size: 1rem;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .odoo-editions-grid,
    .odoo-modules-grid,
    .odoo-diff-grid,
    .odoo-value-highlights {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .odoo-editions-grid,
    .odoo-modules-grid,
    .odoo-diff-grid,
    .odoo-value-highlights {
      grid-template-columns: 1fr;
    }
  }
</style>
