---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="Ecosoft | Sustainable ERP Solutions — Odoo & ERPNext"
  description="Ecosoft is specialized in optimizing business processes with 100% open source software — Odoo & ERPNext consulting, implementation, migration, training, and support."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">100% Open Source · Zero License Fees</p>
        <h1>Open Source ERP Partner for Thai Business</h1>
        <p class="hero-lead">
          We help Thai organisations cut ERP costs by up to 80% using Odoo and ERPNext
          — the world's leading open source platforms. Full source code ownership,
          Thai compliance built in, and a partner that stays with you long after go-live.
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn-primary">Request a Free Consultation</a>
          <a href="#services" class="btn btn-outline">Explore services</a>
        </div>
        <div class="hero-metas">
          <div>
            <p class="metric-number">10+</p>
            <p class="metric-label">years in business</p>
          </div>
          <div>
            <p class="metric-number">4K+</p>
            <p class="metric-label">deployed users</p>
          </div>
          <div>
            <p class="metric-number">40+</p>
            <p class="metric-label">customers</p>
          </div>
          <div>
            <p class="metric-number">120+</p>
            <p class="metric-label">modules contributed</p>
          </div>
        </div>
      </div>
      <div class="hero-card">
        <div class="hero-card-main">
          <h2>What we deliver</h2>
          <ul>
            <li>Full ERP implementation — on time and on budget</li>
            <li>Seamless migration from SAP, Oracle &amp; legacy systems</li>
            <li>Thai accounting, VAT &amp; BOI compliance built in</li>
            <li>Post go-live training &amp; lifetime partnership support</li>
          </ul>
        </div>
        <div class="hero-card-badges">
          <span>OCA Certified</span>
          <span>ERPNext Partner</span>
          <span>100% Open Source</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TECHNOLOGY -->
  <section class="section tech-section">
    <div class="container">
      <p class="eyebrow eyebrow-centered">Our Technology Partners</p>
      <div class="tech-logos">
        <div class="tech-logo-item">
          <img src="/images/oca-logo.png" alt="OCA" />
        </div>
        <div class="tech-logo-item">
          <img src="/images/odoo-logo.png" alt="Odoo" />
        </div>
        <div class="tech-logo-item">
          <img src="/images/frappe-logo.png" alt="Frappe" />
        </div>
        <div class="tech-logo-item">
          <img src="/images/erpnext-logo.png" alt="ERPNext" />
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="section section-alt">
    <div class="container">
      <header class="section-header">
        <p class="eyebrow">Services</p>
        <h2>End-to-End Open Source ERP Services</h2>
        <p>
          From core ERP and government-grade systems to business intelligence
          and process automation — every service is built on 100% open source foundations
          with full source code delivery and no vendor lock-in.
        </p>
      </header>
      <div class="services-list">
        <article class="service-row">
          <img src="/images/services/erp.png" alt="Enterprise Resource Planning" class="service-row-img" loading="lazy" />
          <div class="service-row-body">
            <h3>Enterprise Resource Planning</h3>
            <p>Unify all departments into one seamless system using Odoo or ERPNext — accounting, inventory, sales, purchasing, HR and more.</p>
            <ul>
              <li>Thai accounting &amp; tax compliance</li>
              <li>Custom module development</li>
              <li>Full source code delivery</li>
            </ul>
          </div>
        </article>
        <article class="service-row service-row-reverse">
          <img src="/images/services/government-erp.png" alt="Thai Government ERP" class="service-row-img" loading="lazy" />
          <div class="service-row-body">
            <h3>Thai Government ERP</h3>
            <p>Purpose-built modules for public-sector organisations covering procurement, budget planning, contracts, and asset management.</p>
            <ul>
              <li>Organizational structure management</li>
              <li>Budget planning &amp; control</li>
              <li>Government procurement workflows</li>
            </ul>
          </div>
        </article>
        <article class="service-row">
          <img src="/images/services/dashboard.png" alt="Digital Dashboard" class="service-row-img" loading="lazy" />
          <div class="service-row-body">
            <h3>Digital Dashboard</h3>
            <p>Open source business intelligence powered by Frappe Insights — connect your data securely and visualize KPIs in real time.</p>
            <ul>
              <li>Secure data connections</li>
              <li>Custom charts &amp; reports</li>
              <li>Role-based access control</li>
            </ul>
          </div>
        </article>
        <article class="service-row service-row-reverse">
          <img src="/images/services/automation.png" alt="Process Automation" class="service-row-img" loading="lazy" />
          <div class="service-row-body">
            <h3>Process Automation &amp; API</h3>
            <p>Integrate and automate across systems using n8n — no vendor lock-in, fully self-hosted, and endlessly extensible.</p>
            <ul>
              <li>Cross-system workflow automation</li>
              <li>REST API integrations</li>
              <li>Self-hosted &amp; open source</li>
            </ul>
          </div>
        </article>
        <article class="service-row">
          <img src="/images/services/frappe.png" alt="Frappe Solutions" class="service-row-img" loading="lazy" />
          <div class="service-row-body">
            <h3>Frappe Solutions</h3>
            <p>Beyond ERP — CRM, HR, Learning Management, Helpdesk, Project Collaboration, and Healthcare modules from the Frappe ecosystem.</p>
            <ul>
              <li>Frappe CRM &amp; Helpdesk</li>
              <li>HR &amp; Payroll</li>
              <li>Learning Management System</li>
            </ul>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- METHODOLOGY -->
  <section id="methodology" class="section">
    <div class="container">
      <header class="section-header">
        <p class="eyebrow">Our Approach</p>
        <h2>A Methodology Built for Long-Term Success</h2>
        <p>
          Our methodology is built on four pillars that ensure quality,
          transparency, and a lasting partnership — not just a one-off project.
        </p>
      </header>
      <div class="methodology-grid">
        <div class="cards-grid">
          <article class="info-card pillar-card">
            <span class="pillar-number">01</span>
            <h3>Highest Quality Level</h3>
            <p>
              We work to the high standards of the Odoo Community Association
              (OCA), prioritising code quality and reusability in every module
              we build or contribute.
            </p>
          </article>
          <article class="info-card pillar-card">
            <span class="pillar-number">02</span>
            <h3>Business Expertise</h3>
            <p>
              Over 10 years and 40+ implementations give us deep knowledge of
              Thai business processes, accounting regulations, and tax
              compliance requirements.
            </p>
          </article>
          <article class="info-card pillar-card">
            <span class="pillar-number">03</span>
            <h3>No Vendor Lock-In</h3>
            <p>
              We deliver all source code at project completion so you own your
              system. Open source means freedom — from licensing fees and from
              dependency on a single vendor.
            </p>
          </article>
          <article class="info-card pillar-card">
            <span class="pillar-number">04</span>
            <h3>Long-Term Partnership</h3>
            <p>
              We commit to long-term relationships. Our team stays with you
              after go-live to ensure the system grows with your business and
              continues to deliver value.
            </p>
          </article>
        </div>
        <div class="methodology-img-wrap">
          <img src="/images/approach.png" alt="Our approach" class="methodology-img" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section id="testimonials" class="section section-alt">
    <div class="container">
      <header class="section-header">
        <p class="eyebrow">Client Testimonials</p>
        <h2>Trusted by Leading Thai Organisations</h2>
        <p>
          From manufacturing and logistics to government agencies and
          space technology — our clients operate across every major sector.
        </p>
      </header>
      <div class="testimonials-grid">
        <article class="testimonial-card">
          <blockquote class="testimonial-quote">
            "The system allows management to track production in real time.
            Since 2013 Ecosoft has been our trusted ERP partner."
          </blockquote>
          <div class="testimonial-meta">
            <span class="testimonial-name">Nantachai Siripronprasarn</span>
            <span class="testimonial-company">Raja Cycle</span>
          </div>
        </article>
        <article class="testimonial-card">
          <blockquote class="testimonial-quote">
            "Odoo replaced our SAP system in 2018. The flexibility and
            cost savings have been remarkable for our organisation."
          </blockquote>
          <div class="testimonial-meta">
            <span class="testimonial-name">Varunee Leeladhanawithaya</span>
            <span class="testimonial-company">NSTDA (Vice President)</span>
          </div>
        </article>
        <article class="testimonial-card">
          <blockquote class="testimonial-quote">
            "Moving from spreadsheets to Odoo with Ecosoft dramatically
            reduced errors and gave us full visibility across the business."
          </blockquote>
          <div class="testimonial-meta">
            <span class="testimonial-name">Somboon Thannyavun</span>
            <span class="testimonial-company">Square Panel Systems</span>
          </div>
        </article>
        <article class="testimonial-card">
          <blockquote class="testimonial-quote">
            "ERPNext is a perfect fit for us. Ecosoft's ability to customise
            without compromising the core system is what sets them apart."
          </blockquote>
          <div class="testimonial-meta">
            <span class="testimonial-name">Athip Rungkirtikul</span>
            <span class="testimonial-company">Lamphun Plastpack</span>
          </div>
        </article>
        <article class="testimonial-card">
          <blockquote class="testimonial-quote">
            "ERPNext has become our core infrastructure. It enables rapid
            decision-making that is critical for a space-tech startup."
          </blockquote>
          <div class="testimonial-meta">
            <span class="testimonial-name">Supidit Boonnawattanam</span>
            <span class="testimonial-company">EOS Orbit (CEO) — Thailand's first satellite manufacturer</span>
          </div>
        </article>
      </div>

      <script is:inline>
        (function () {
          var cards = document.querySelectorAll('.testimonial-card');
          var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('testimonial-card--visible');
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.2 });
          cards.forEach(function (card) { observer.observe(card); });
        })();
      </script>
    </div>
  </section>

  <!-- CUSTOMER LOGOS -->
  <section class="section section-logos">
    <div class="container">
      <p class="eyebrow eyebrow-centered">Trusted by 40+ organisations across Thailand</p>
      <div class="logos-grid">
        {["nstda","biotec","nxpo","hii","bdi","cmo","cft","aal","acm","easy","esb","fofo","hwf","mcic","mh","monta","optima","rex","rjc","shm","sqp","thaiev","tti","usp","aab","skyviv","rje","jv_control","lpp"].map((logo) => (
          <div class="logo-item">
            <img src={`/images/cust_logo/${logo}.png`} alt={`${logo.toUpperCase()} logo`} loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section section-accent">
    <div class="container contact-grid">
      <div>
        <p class="eyebrow eyebrow-light">Get in Touch</p>
        <h2>Start Your ERP Transformation Today</h2>
        <p>
          Tell us about your business and current systems. Our team will respond
          within one business day with a no-obligation assessment.
        </p>
        <ul class="contact-meta">
          <li>Free initial consultation &amp; demo</li>
          <li>ERP readiness &amp; ROI assessment</li>
          <li>Migration &amp; implementation planning</li>
        </ul>
      </div>
      <form class="contact-form" id="contact-form" novalidate>
        <div class="form-row">
          <label for="contact-name">Name <span aria-hidden="true">*</span></label>
          <input id="contact-name" type="text" name="name" placeholder="Your full name" required />
          <label for="contact-company">Company</label>
          <input id="contact-company" type="text" name="company" placeholder="Company name" />
        </div>
        <div class="form-row">
          <label for="contact-email">Email <span aria-hidden="true">*</span></label>
          <input id="contact-email" type="email" name="email" placeholder="you@example.com" required />
          <label for="contact-phone">Phone</label>
          <input id="contact-phone" type="tel" name="phone" placeholder="+66 ..." />
        </div>
        <label for="contact-system">Current system</label>
        <input id="contact-system" type="text" name="current_system" placeholder="e.g. SAP, spreadsheets, custom software" />
        <label for="contact-message">Message <span aria-hidden="true">*</span></label>
        <textarea
          id="contact-message"
          name="message"
          rows="4"
          placeholder="Describe your current system, pain points, and ERP goals."
          required
        ></textarea>
        <div id="form-success" class="form-success" hidden>
          Thank you! We'll be in touch within one business day.
        </div>
        <button type="submit" class="btn btn-primary btn-full">
          Send inquiry
        </button>
        <p class="form-note">
          Your information is kept strictly confidential and used only to respond to your inquiry.
        </p>
      </form>
      <script is:inline>
        (function () {
          var form = document.getElementById('contact-form');
          if (!form) return;
          form.addEventListener('submit', function (e) {
            e.preventDefault();
            if (!form.checkValidity()) {
              form.reportValidity();
              return;
            }
            var success = document.getElementById('form-success');
            if (success) success.removeAttribute('hidden');
            form.reset();
          });
        })();
      </script>
    </div>
  </section>
</BaseLayout>
